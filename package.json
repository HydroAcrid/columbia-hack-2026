{
  "name": "launch-copilot",
  "private": true,
  "packageManager": "pnpm@10.31.0",
  "scripts": {
    "dev": "pnpm --filter @copilot/web dev",
    "dev:agent": "pnpm --filter @copilot/agent dev",
    "dev:all": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp", "unrs-resolver"]
  }
}
